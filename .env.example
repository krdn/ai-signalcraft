# ============================================================
# AI SignalCraft — 환경변수 템플릿
# ============================================================
# 개발: apps/web/.env.local에 복사 후 값 채우기
# 운영: 서버의 .env.production에 설정 (docker-compose.prod.yml에서 로드)
# ============================================================

# --- Auth (NextAuth.js) ---
# openssl rand -base64 32
AUTH_SECRET=your_auth_secret
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# --- Database (ais-prod-postgres 공유 또는 로컬 전용 DB) ---
DATABASE_URL=postgresql://ais:ais_secure_pw@192.168.0.5:5438/ai_signalcraft

# --- Redis (ais-prod-redis 공유, BULL_PREFIX로 네임스페이스 분리) ---
REDIS_URL=redis://192.168.0.5:6385

# --- BullMQ 큐 prefix ---
# 운영: 'bull' (BullMQ 기본값, 기존 큐 호환)
# 개발: 'ais-dev' (미설정 시 NODE_ENV!=production 자동 적용)
# BULL_PREFIX=ais-dev

# --- Google OAuth (선택) ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Resend (선택 — 초대 이메일 발송) ---
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=AI SignalCraft <onboarding@resend.dev>

# --- YouTube Data API ---
YOUTUBE_API_KEY=your_youtube_api_key

# --- AI 프로바이더 (환경변수 직접 사용 시) ---
# DB의 provider_keys를 사용하려면 ENCRYPTION_KEY 설정 필요
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# --- DB provider_keys 암호화 키 (선택) ---
# openssl rand -base64 32
ENCRYPTION_KEY=your_encryption_key

# Gemini CLI OAuth 클라이언트 (gemini-cli-core 공개 값)
# https://github.com/google-gemini/gemini-cli 참고
GEMINI_OAUTH_CLIENT_ID=your_gemini_oauth_client_id
GEMINI_OAUTH_CLIENT_SECRET=your_gemini_oauth_client_secret
