# TimescaleDB 연결 (krdn-timescaledb:5435, 신규 DB ais_collection)
DATABASE_URL=postgres://postgres:postgres@192.168.0.5:5435/ais_collection

# Redis (ais-prod-redis와 공유, prefix 'collector'로 큐 분리)
REDIS_URL=redis://192.168.0.5:6385

# 수집 서비스 포트
PORT=3400

# 내부 서비스 간 인증 키 (apps/web과 공유)
COLLECTOR_API_KEY=change-me-in-production

# 환경 식별
NODE_ENV=development

# 스케줄러 스캔 주기 (초)
SCHEDULER_SCAN_INTERVAL_SEC=60

# 수동 트리거 쿨다운 (초)
MANUAL_TRIGGER_COOLDOWN_SEC=600
